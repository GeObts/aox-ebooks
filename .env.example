# AOX App Environment Variables

# Required: Base Mainnet RPC
NEXT_PUBLIC_RPC_URL=https://mainnet.base.org

# Required: WalletConnect Project ID (for additional wallets)
NEXT_PUBLIC_WC_PROJECT_ID=ed0954223df16d7761fcc0402032eb81

# Optional: Beta access password (default: aoxbeta2026)
NEXT_PUBLIC_ACCESS_PASSWORD=aoxbeta2026

# Optional: Resend API Key (for email subscription)
RESEND_API_KEY=your_resend_api_key_here
